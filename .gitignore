# macOS
.DS_Store

# Python
__pycache__/
*.pyc

# --- Large QoG source files (NOT committed) ---------------------------------
# The pipeline uses only the committed slim ICRG subset `qog_icrg_jan26.csv`
# (ccodealp/year/icrg_qog, ~150 KB).  The full QoG Standard Time-Series releases
# are 60-70 MB; jan25 is unused.  See README for how to obtain the full file.
qog_std_ts_jan25.csv
qog_std_ts_jan26.csv

# eschome scraper cache (raw HTTP responses; regenerated by scrape_eschome.py)
extension/output/eschome_cache/

# NB: the derived panels (master*.csv, regression_data*.csv) ARE committed for
# convenience even though run_all.py / run_all_extension.py regenerate them.

